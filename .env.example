# =====================================================
# CREDENCIALES OLYMPIC GYM
# =====================================================
OLYMPIC_EMAIL=perezfernanda2712@gmail.com
OLYMPIC_PASSWORD=CONTRASEÑA_PROVISIONAL_AQUI

# =====================================================
# CREDENCIALES TELEGRAM
# =====================================================
# Para obtener el token: hablar con @BotFather en Telegram y crear un bot
# Para obtener el chat_id: hablar con @userinfobot o enviar un mensaje al bot
# y luego visitar: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=TOKEN_AQUI
TELEGRAM_CHAT_ID=CHAT_ID_AQUI

# =====================================================
# VENTANA DE EJECUCIÓN (hora local)
# =====================================================
# El bot solo intenta reservar entre estas dos horas.
# Fuera de esta ventana sale inmediatamente.
TARGET_START_TIME=07:00
TARGET_END_TIME=07:05

# =====================================================
# HORARIO DE LA CLASE A RESERVAR
# =====================================================
TARGET_CLASS_START=09:00
TARGET_CLASS_END=10:00

# =====================================================
# COMPORTAMIENTO
# =====================================================
# Cada cuántos segundos revisar si el botón cambió a "Reservar"
CHECK_INTERVAL_SECONDS=1

# headless=true => navegador oculto (para producción / tarea programada)
# headless=false => navegador visible (útil para depurar)
HEADLESS=false

# DRY_RUN=true  => detecta el botón pero NO hace clic en Reservar (modo prueba seguro)
# DRY_RUN=false => sí reserva cuando el botón esté disponible (modo producción)
DRY_RUN=true

# URL del portal (no debería cambiar, pero queda configurable)
LOGIN_URL=https://reservas.olympicgym.cl/accounts/login/?next=/agenda/
AGENDA_URL=https://reservas.olympicgym.cl/agenda/
